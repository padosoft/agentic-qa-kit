{
  "name": "@aqa/admin",
  "version": "0.0.1",
  "description": "Admin panel for agentic-qa-kit — wired SPA over runs, findings, packs, audit log.",
  "type": "module",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "dev": "vite",
    "preview": "vite preview",
    "test": "node --experimental-strip-types --no-warnings=ExperimentalWarning --test test/router.test.ts",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; for (const p of ['dist','.tsbuildinfo','node_modules/.vite']) { try { rmSync(p, { recursive: true, force: true }); } catch {} }\""
  },
  "dependencies": {
    "@aqa/reporter": "workspace:*",
    "@aqa/schemas": "workspace:*",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-router": "^1.95.0",
    "@tanstack/react-table": "^8.20.5",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "vite": "^6.0.1"
  }
}
