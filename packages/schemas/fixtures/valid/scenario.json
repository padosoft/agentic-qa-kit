{
  "schema_version": "1",
  "id": "scn-token-replay",
  "title": "Old token must be rejected within 60s of rotation",
  "risk_refs": ["r-auth-bypass"],
  "invariant_refs": ["inv-token-rotation"],
  "preconditions": ["user logged in", "token captured"],
  "steps": [
    {
      "id": "probe-rotate",
      "kind": "http",
      "with": { "method": "POST", "url": "/auth/rotate" },
      "timeout_ms": 5000
    },
    {
      "id": "probe-use-old",
      "kind": "http",
      "with": { "method": "GET", "url": "/me", "auth": "${OLD_TOKEN}" },
      "timeout_ms": 5000
    }
  ],
  "oracles": [{ "id": "o-401", "kind": "http_status", "with": { "expected": 401 }, "weight": 1 }],
  "cleanup": [],
  "tags": ["auth"],
  "seed": "0xdeadbeef"
}
