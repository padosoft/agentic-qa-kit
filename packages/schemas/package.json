{
  "name": "@aqa/schemas",
  "version": "0.0.1",
  "description": "Source of truth for all agentic-qa-kit data shapes: JSON Schemas + TypeScript types + Zod runtime validators.",
  "type": "module",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schemas/*": "./schemas/*",
    "./fixtures/*": "./fixtures/*"
  },
  "files": ["dist", "schemas", "fixtures", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/emit-json-schemas.mjs",
    "build:schemas": "node scripts/emit-json-schemas.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "tsc -p tsconfig.json && node scripts/emit-json-schemas.mjs",
    "test": "node --experimental-strip-types --no-warnings=ExperimentalWarning --test test/validators.test.ts test/ajv-roundtrip.test.ts",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; for (const p of ['dist','.tsbuildinfo']) { try { rmSync(p, { recursive: true, force: true }); } catch {} }\""
  },
  "dependencies": {
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "zod-to-json-schema": "^3.23.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
