{
  "$ref": "#/definitions/notification",
  "definitions": {
    "notification": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1"
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "^[a-z0-9](?:-?[a-z0-9])*$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "run.failed",
            "finding.critical",
            "finding.verified",
            "budget.threshold",
            "audit.chain_broken",
            "pack.install_failed",
            "queue.stuck",
            "user.invited"
          ]
        },
        "at": {
          "type": "string",
          "format": "date-time"
        },
        "org": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z0-9](?:-?[a-z0-9])*$"
        },
        "project": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z0-9](?:-?[a-z0-9])*$"
        },
        "actor": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "payload": {
          "type": "object",
          "additionalProperties": {},
          "default": {}
        },
        "read_by": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": []
        }
      },
      "required": [
        "schema_version",
        "id",
        "kind",
        "at",
        "org",
        "project",
        "actor",
        "summary"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
