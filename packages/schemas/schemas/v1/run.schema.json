{
  "$ref": "#/definitions/run",
  "definitions": {
    "run": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1"
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "pattern": "^[a-z0-9](?:-?[a-z0-9])*$"
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "finished_at": {
          "type": "string",
          "format": "date-time"
        },
        "state": {
          "type": "string",
          "enum": [
            "pending",
            "running",
            "succeeded",
            "failed",
            "aborted",
            "budget_exceeded"
          ]
        },
        "project": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z0-9](?:-?[a-z0-9])*$"
        },
        "profile": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z0-9](?:-?[a-z0-9])*$"
        },
        "execution_mode": {
          "type": "string",
          "enum": [
            "orchestrator",
            "agent"
          ]
        },
        "config_snapshot": {
          "type": "object",
          "properties": {
            "profile": {
              "type": "string",
              "minLength": 1,
              "maxLength": 64,
              "pattern": "^[a-z0-9](?:-?[a-z0-9])*$"
            },
            "execution_mode": {
              "type": "string",
              "enum": [
                "orchestrator",
                "agent"
              ]
            },
            "packs": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 64,
                "pattern": "^[a-z0-9](?:-?[a-z0-9])*$"
              },
              "default": []
            },
            "llm": {
              "type": "object",
              "properties": {
                "provider": {
                  "type": "string"
                },
                "model_id": {
                  "type": "string"
                },
                "model_version_hash": {
                  "type": "string"
                },
                "api_version": {
                  "type": "string"
                },
                "region": {
                  "type": "string"
                }
              },
              "required": [
                "provider",
                "model_id"
              ],
              "additionalProperties": false
            },
            "prompt_hash": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            },
            "config_hash": {
              "type": "string",
              "pattern": "^[a-f0-9]{64}$"
            }
          },
          "required": [
            "profile",
            "execution_mode",
            "config_hash"
          ],
          "additionalProperties": false
        },
        "totals": {
          "type": "object",
          "properties": {
            "scenarios": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            },
            "findings": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            },
            "probes": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            },
            "llm_tokens_in": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            },
            "llm_tokens_out": {
              "type": "integer",
              "minimum": 0,
              "default": 0
            },
            "llm_cost_usd": {
              "type": "number",
              "minimum": 0,
              "default": 0
            }
          },
          "additionalProperties": false
        },
        "artifact_dir": {
          "type": "string"
        }
      },
      "required": [
        "schema_version",
        "id",
        "started_at",
        "state",
        "project",
        "profile",
        "execution_mode",
        "config_snapshot",
        "totals",
        "artifact_dir"
      ],
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "state": {
            "enum": [
              "succeeded",
              "failed",
              "aborted",
              "budget_exceeded"
            ]
          }
        },
        "required": [
          "state"
        ]
      },
      "then": {
        "required": [
          "finished_at"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "state": {
            "enum": [
              "pending",
              "running"
            ]
          }
        },
        "required": [
          "state"
        ]
      },
      "then": {
        "not": {
          "required": [
            "finished_at"
          ]
        }
      }
    }
  ],
  "$comment": "finished_at >= started_at is enforced by the Zod validator; JSON Schema cannot express the cross-field comparison.",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
