{
  "$ref": "#/definitions/project-ref",
  "definitions": {
    "project-ref": {
      "type": "object",
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "1"
        },
        "org": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z0-9](?:-?[a-z0-9])*$"
        },
        "slug": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z0-9](?:-?[a-z0-9])*$"
        },
        "display_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "archived_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "schema_version",
        "org",
        "slug",
        "display_name",
        "created_at"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
